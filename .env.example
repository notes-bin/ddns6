# ============================================================
# DDNS6 环境变量模板
#
# 使用方式：
#   1. cp .env.example .env
#   2. 编辑 .env 填入你的配置
#   3. docker compose up -d
# ============================================================

# ============ 通用配置（必填） ============
DOMAIN=example.com
# 子域名，多个用逗号分隔（docker-compose 中只支持单值，多子域名请使用配置文件模式）
SUBDOMAIN=www
# 监听的网络接口（仅 Linux Netlink 模式，如 ppp0，留空监听所有）
INTERFACE=
# DNS 记录 TTL（秒，默认 600）
TTL=600
# 非 Linux 平台轮询间隔（默认 5m）
INTERVAL=5m
# 调试日志（设置任意非空值启用）
DEBUG=

# ============ 腾讯云 DNSPod (API v3) ============
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# ============ 阿里云 DNS ============
ALICLOUD_ACCESS_KEY_ID=
ALICLOUD_ACCESS_KEY_SECRET=

# ============ Cloudflare DNS ============
CLOUDFLARE_API_TOKEN=

# ============ GoDaddy DNS ============
GODADDY_API_KEY=
GODADDY_API_SECRET=

# ============ 华为云 DNS ============
HUAWEI_USERNAME=
HUAWEI_PASSWORD=
HUAWEI_DOMAIN_NAME=

# ============ DuckDNS (免费 DDNS) ============
DUCKDNS_TOKEN=

# ============ No-IP (经典 DDNS) ============
NOIP_USERNAME=
NOIP_PASSWORD=

# ============ Hurricane Electric (免费 DNS 托管) ============
HE_PASSWORD=

# ============ Dynv6 (免费 IPv6 DDNS) ============
DYNV6_TOKEN=

# ============ Porkbun DNS API ============
PORKBUN_API_KEY=
PORKBUN_API_SECRET=

# ============ DigitalOcean DNS API ============
DIGITALOCEAN_TOKEN=

# ============ 百度云 DNS ============
BAIDU_ACCESS_KEY=
BAIDU_SECRET_KEY=

# ============ DNSPod (旧版 API) ============
DNSPOD_LOGIN_TOKEN=
