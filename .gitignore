# Release archives
# ============================================================
*.tar.gz
*.zip

# ============================================================
# IDE / Editor
# ============================================================
.idea/
.vscode/
*.swp
*.swo
*~
tags                           # ctags 生成的索引文件

# ============================================================
# OS
# ============================================================
.DS_Store
.Thumbs.db

# ============================================================
# Go
# ============================================================
go.work
go.work.sum
vendor/                        # 取消注释以启用 vendor 目录
